@model IEnumerable<ProjectApprovalSystem.Controllers.UserViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold">Admin: Manage All Users</h2>
    </div>

    <div class="card shadow-sm border-danger mt-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Email Address</th>
                            <th>Role</th>
                            <th>Reset Password</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="fw-bold">@user.Email</td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else if (user.Role == "Supervisor")
                                    {

                                        <span class="badge bg-info">Supervisor</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-warning text-dark">Student</span>
                                    }
                                </td>
                           
                                <td>
                                    @if (user.Email != "admin@pas.com")
                                    {
                                        <form asp-action="ResetPassword" method="post" class="d-flex">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <input type="text" name="newPassword" class="form-control form-control-sm me-2" placeholder="New Password (e.g. Test@123!)" required />
                                            <button type="submit" class="btn btn-sm btn-outline-dark fw-bold">Reset</button>
                                        </form>
                                    }
                                </td>

                            
                                <td>
                                    @if (user.Email != "admin@pas.com")
                                    {
                                        <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete this user completely?');">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold">Delete</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Cannot delete Admin</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>