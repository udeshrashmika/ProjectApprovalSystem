<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectApprovalSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectApprovalSystem.styles.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="text-info">PAS</span> | BlindMatch
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-bold" asp-area="" asp-controller="Student" asp-action="Create">Submit Proposal</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light fw-bold" asp-area="" asp-controller="Student" asp-action="MyStatus">My Status</a>
                                </li>
                            }

                            @if (User.IsInRole("Supervisor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-info fw-bold" asp-area="" asp-controller="Supervisor" asp-action="BlindDashboard">Blind Dashboard</a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-area="" asp-controller="Admin" asp-action="Oversight">Admin Oversight</a>
                                </li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            <div class="card shadow-sm border-0 p-4 bg-white" style="border-radius: 15px;">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto">
        <div class="container text-center py-3">
            &copy; 2026 - <span class="fw-bold">ProjectApprovalSystem</span> - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>