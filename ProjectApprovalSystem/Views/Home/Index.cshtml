@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4 fw-bold">Project Approval System</h1>
    <p class="lead text-muted">A secure, blind-matching platform for Students and Supervisors.</p>
    <hr class="my-4" style="width: 50%; margin: auto;">
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="p-3 border rounded bg-light">
                <h5 class="text-info">Students</h5>
                <p class="small">Submit your proposals anonymously.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 border rounded bg-light">
                <h5 class="text-info">Supervisors</h5>
                <p class="small">Review and match with research areas.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 border rounded bg-light">
                <h5 class="text-info">Admin</h5>
                <p class="small">Manage system roles and oversight.</p>
            </div>
        </div>
    </div>
</div>