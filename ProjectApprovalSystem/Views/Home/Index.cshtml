@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4 fw-bold">Project Approval System</h1>
    <p class="lead text-muted">A secure, blind-matching platform for Students and Supervisors.</p>
    <hr class="my-4" style="width: 50%; margin: auto;">

    <div class="row mt-5 justify-content-center">
        @if (!User.Identity.IsAuthenticated)
        {
            <div class="col-md-8">
                <div class="p-5 border rounded bg-white shadow-sm">
                    <h2 class="text-dark fw-bold">Welcome to PAS | BlindMatch</h2>
                    <p class="text-muted">Please use the <b>Register</b> or <b>Login</b> links in the top right corner to access your account.</p>
                    <hr class="my-4">
                    <div class="row text-start mt-4">
                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold text-primary">Students</h6>
                            <p class="small text-muted">Register as a student to submit your project proposals anonymously.</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold text-info">Supervisors</h6>
                            <p class="small text-muted">Access the blind dashboard to review abstracts and match with projects.</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            if (User.IsInRole("Student"))
            {
                <div class="col-md-8">
                    <div class="p-4 border rounded bg-white shadow-sm border-start border-warning border-5">
                        <h5 class="text-warning fw-bold">Student Portal</h5>
                        <p class="small">Submit your project proposals anonymously for supervisor review.</p>
                        <a class="btn btn-warning text-dark fw-bold" asp-controller="Student" asp-action="Create">Submit New Proposal</a>
                    </div>
                </div>
            }

            if (User.IsInRole("Supervisor"))
            {
                <div class="col-md-8">
                    <div class="p-4 border rounded bg-white shadow-sm border-start border-info border-5">
                        <h5 class="text-info fw-bold">Supervisor Dashboard</h5>
                        <p class="small">Review abstracts anonymously and confirm matches with research areas.</p>
                        <a class="btn btn-info text-white fw-bold" asp-controller="Supervisor" asp-action="BlindDashboard">View Dashboard</a>
                    </div>
                </div>
            }

            if (User.IsInRole("Admin"))
            {
                <div class="col-md-8 mt-3">
                    <div class="p-4 border rounded bg-white shadow-sm border-start border-danger border-5">
                        <h5 class="text-danger fw-bold">Admin Oversight</h5>
                        <p class="small">Manage system roles and oversee student-supervisor pairings[cite: 21].</p>
                        <a class="btn btn-danger fw-bold" asp-controller="Admin" asp-action="Oversight">Manage System</a>
                    </div>
                </div>
            }
        }
    </div>
</div>