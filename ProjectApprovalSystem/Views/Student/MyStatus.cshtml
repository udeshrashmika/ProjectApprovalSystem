@model BlindMatchPAS.Models.ProjectProposal

@{
    ViewData["Title"] = "My Proposal Status";
}

<div class="container mt-5">
    <h2 class="text-primary fw-bold mb-4">Proposal Status</h2>

    @if (Model == null)
    {
        <div class="alert alert-warning shadow-sm border-0">
            <i class="bi bi-exclamation-triangle-fill"></i> You have not submitted a project proposal yet.
            <a asp-action="Create" class="alert-link">Click here to submit one.</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="card-title fw-bold">@Model.Title</h4>
                <p class="text-muted"><span class="badge bg-secondary">@Model.ResearchArea</span></p>
                <hr />
                <div class="row mb-3">
                    <div class="col-md-3 fw-bold">Status:</div>
                    <div class="col-md-9">
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark fs-6">Pending Review</span>
                        }
                        else if (Model.Status == "Approved")
                        {
                            <span class="badge bg-success fs-6">Approved & Matched!</span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">@Model.Status</span>
                        }
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-3 fw-bold">Tech Stack:</div>
                    <div class="col-md-9">@Model.TechStack</div>
                </div>
                <div class="row">
                    <div class="col-md-3 fw-bold">Abstract:</div>
                    <div class="col-md-9">@Model.Abstract</div>
                </div>
            </div>
        </div>
    }
</div>