@model BlindMatchPAS.Models.ProjectProposal

@{
    ViewData["Title"] = "Project Details";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-dark text-white p-3" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0">Reviewing Proposal: @Model.Title</h4>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-8">
                    <h5 class="text-primary fw-bold">Project Overview</h5>
                    <hr />
                    <dl class="row">
                        <dt class="col-sm-3">Research Area</dt>
                        <dd class="col-sm-9"><span class="badge bg-info">@Model.ResearchArea</span></dd>

                        <dt class="col-sm-3">Tech Stack</dt>
                        <dd class="col-sm-9">@Model.TechStack</dd>

                        <dt class="col-sm-3">Abstract</dt>
                        <dd class="col-sm-9 text-justify" style="line-height: 1.6;">@Model.Abstract</dd>

                        <dt class="col-sm-3">Current Status</dt>
                        <dd class="col-sm-9">
                            <span class="badge @(Model.Status == "Matched" ? "bg-success" : "bg-warning text-dark")">
                                @Model.Status
                            </span>
                        </dd>
                    </dl>
                </div>

                <div class="col-md-4 border-start">
                    <h5 class="fw-bold">Actions & Identity</h5>
                    <hr />
                    
                    @if (Model.Status == "Matched")
                    {
                        <div class="alert alert-success shadow-sm">
                            <h6 class="alert-heading fw-bold"><i class="bi bi-person-check"></i> Identity Revealed</h6>
                            <hr>
                            <p class="mb-1 small"><strong>Student Email:</strong></p>
                            <p class="fw-bold">@Model.StudentEmail</p>
                        </div>
                        <button class="btn btn-secondary w-100" disabled>Already Matched</button>
                    }
                    else
                    {
                        <div class="alert alert-secondary shadow-sm mb-4">
                            <h6 class="alert-heading fw-bold"><i class="bi bi-eye-slash"></i> Blind Mode</h6>
                            <p class="small mb-0">Student details are hidden. Confirm matching to reveal contact information.</p>
                        </div>

                        <form asp-action="ConfirmMatch" asp-controller="Supervisor" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm fw-bold">
                                Confirm Match
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
        <div class="card-footer bg-light p-3">
            <a asp-action="BlindDashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>